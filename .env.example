# ==============================================
# Universal AI Adapter - Configuration Template
# ==============================================
# Copy this file to .env and fill in your values

# --- Primary AI Provider (Choose ONE) ---
# Options: ollama, openai, anthropic, groq, deepseek, none
AI_PROVIDER=ollama

# --- Enable Automatic Fallback ---
# If primary provider fails, try fallback providers
ENABLE_FALLBACK=true

# --- Fallback Order ---
# Comma-separated list of providers to try after primary fails
# Example: groq,ollama or anthropic,groq,ollama
FALLBACK_ORDER=groq,ollama

# --- Verbose Logging ---
# Set to true to see provider switches and debug info
VERBOSE=false

# --- Request Timeout (milliseconds) ---
TIMEOUT=60000

# ==============================================
# Provider Configurations
# ==============================================

# --- Ollama (FREE - Local, No API Key) ---
# Download: https://ollama.com
# Usage: ollama serve && ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- OpenAI (Paid) ---
# Get API key: https://platform.openai.com/api-keys
# Pricing: https://openai.com/pricing
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic Claude (Paid) ---
# Get API key: https://console.anthropic.com/settings/keys
# Pricing: https://www.anthropic.com/pricing
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Groq (Free Tier Available) ---
# Get API key: https://console.groq.com/keys
# Free: 10,000 requests/day, 7,000 RPM
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile

# --- DeepSeek (Budget-Friendly) ---
# Get API key: https://platform.deepseek.com/api_keys
# Very affordable pricing
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# ==============================================
# Usage Examples
# ==============================================

# Example 1: Free with Ollama (recommended for development)
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Example 2: Production with fallback
# AI_PROVIDER=openai
# ENABLE_FALLBACK=true
# FALLBACK_ORDER=groq,ollama
# OPENAI_API_KEY=sk-proj-...
# GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434

# Example 3: Cost-optimized with Groq free tier
# AI_PROVIDER=groq
# ENABLE_FALLBACK=true
# FALLBACK_ORDER=ollama
# GROQ_API_KEY=gsk_...
# OLLAMA_BASE_URL=http://localhost:11434

# ==============================================
# Security Notes
# ==============================================
# - NEVER commit this file to version control
# - Keep API keys secure
# - Use environment-specific .env files
# - Rotate keys regularly
# - Use secrets manager in production (AWS Secrets Manager, HashiCorp Vault, etc.)
