{
  "name": "universal-ai-adapter",
  "version": "1.2.0",
  "description": "Universal adapter for multiple AI providers with automatic fallback",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/universal-ai-adapter"
  },
  "homepage": "https://github.com/anomalyco/universal-ai-adapter#readme",
  "bugs": {
    "url": "https://github.com/anomalyco/universal-ai-adapter/issues"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "groq",
